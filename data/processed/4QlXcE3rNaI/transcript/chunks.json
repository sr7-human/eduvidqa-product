  {
    "chunk_id": "chunk_002",
    "start_time": 20.0,
    "end_time": 30.0,
    "text": "\u0932\u093e\u0938\u094d\u091f \u0915\u0941\u091b \u0935\u0940\u0921\u093f\u092f\u094b\u0938 \u092e\u0947\u0902 \u0939\u092e\u0928\u0947 \u092c\u093e\u0924 \u0915\u0940 \u0939\u0948 \u0921\u094d\u092f\u0941\u0905\u0932\u093f\u091f\u0940 \u0915\u0940 \u0938\u0947\u0932\u094d\u092b \u0921\u0941 \u090f\u0932\u093f\u091f\u0940 \u0915\u0940 \u0909\u0938\u0940 \u0921\u093f\u0938\u094d\u0915\u0936\u0928 \u0915\u094b \u0906\u0917\u0947 \u0915\u0930\u0924\u093e \u0939\u0942\u0902 \u0907\u0938 \u0935\u0940\u0921\u093f\u092f\u094b \u092e\u0947\u0902 \u092c\u093e\u0924 \u0915\u0930\u0947\u0902\u0917\u0947 \u0915\u093f",
