    "text": "\u0928\u092e\u0938\u094d\u0915\u093e\u0930 \u0926\u094b\u0938\u094d\u0924\u094b\u0902 \u092e\u0948\u0902 \u0939\u0942\u0902 \u0906\u092a\u0915\u093e \u0926\u094b\u0938\u094d\u0924 \u0938\u0902\u091a\u093f\u0924 \u0914\u0930 \u0938\u094d\u0935\u093e\u0917\u0924 \u0915\u0930\u0924\u093e \u0939\u0942\u0902 \u0907\u0938 \u0935\u0940\u0921\u093f\u092f\u094b \u0938\u0940\u0930\u0940\u091c \u092e\u0947\u0902 \u091c\u0939\u093e\u0902 \u0939\u092e \u0921\u093f\u0938\u094d\u0915\u0936\u0928 \u0915\u0930 \u0930\u0939\u0947 \u0939\u0948\u0902 \u0921\u093f\u091c\u093f\u091f\u0932 \u0907\u0932\u0947\u0915\u094d\u091f\u094d\u0930\u0949\u0928\u093f\u0915\u094d\u0938 \u092a\u0930 \u0926\u094b\u0938\u094d\u0924\u094b\u0902 \u0905\u092d\u0940 \u0915\u0941\u091b \u092b\u0902\u0915\u094d\u0936\u0902\u0938 \u0915\u0940 \u092a\u094d\u0930\u0949\u092a\u0930\u094d\u091f\u0940 \u0921\u093f\u0938\u094d\u0915\u0938 \u0915\u0930 \u0930\u0939\u0947 \u0925\u0947",
